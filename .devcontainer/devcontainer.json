{
  "name": "PHP HTTPS Dev Container",
  "image": "mcr.microsoft.com/devcontainers/php:1.2",
  "forwardPorts": [80, 443],
  "postCreateCommand": "apt-get update && apt-get install -y openssl",
  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client"
      ]
    }
  }
}

